{"pageProps":{"data":"<h5>数据类型</h5>\n<table id=\"Af\">\n    <script>\n        _MiMethod.td([\n        [\"boolean\",\"布尔值\"],\n        [\"byte\",\"字节\"],\n        [\"char\",\"字符\"],\n        [\"double\",\"双精度浮点\"],\n        [\"float\",\"单精度浮点\"],\n        [\"int\",\"整形\"],\n        [\"long\",\"长整形\"],\n        [\"short\",\"短整形\"],\n    ])\n    </script>\n</table>\n<h5>变量使用</h5>\n<table id=\"Ag\"></table>\n<script>\n    _MiMethod.td(\"Ag\",\n    [\n    [\"super\",\"超类\"],    \n    [\"this\",\"this\"],    \n    [\"void\",\"空\"],    \n]\n    );\n</script>\n<h5>访问控制</h5>\n<table id=\"Aa\">\n    <script>\n        _MiMethod.td(\"Aa\",[\n        [\"private\",\"私有\"], \n        [\"protected\",\"受保护\"], \n        [\"public\",\"公共\"], \n        [\"default\",\"默认\"], \n    ]);\n    </script>\n</table>\n<h5>类、方法 、变量修饰符</h5>\n<table id=\"Ab\">\n    <script>\n        _MiMethod.td(\"Ab\",[\n        [\"abstract\",\"抽象\"],\n        [\"class\",\"类\"],\n        [\"extends\",\"扩从\"],\n        [\"final\",\"不可变的\"],\n        [\"implements\",\"实现 interface\"],\n        [\"interface\",\"接口\"],\n        [\"native\",\"本地\"],\n        [\"new\",\"实现\"],\n        [\"static\",\"静态\"],\n        [\"strictfp\",\"严格\"],\n        [\"synchronized\",\"线程\"],\n        [\"transient\",\"暂时\"],\n        [\"volatile\",\"易失\"],\n    ])\n    </script>\n</table>\n<h5>程序控制语句</h5>\n<table id=\"Ac\">\n    <script>\n _MiMethod.td(\"Ac\",[\n        [\"break\",\"跳出循环\"],\n        [\"case\",\"用于 switch\"],\n        [\"continue\",\"继续下次循环\"],\n        [\"do\",\"执行\"],\n        [\"else\",\"否则，用于 if\"],\n        [\"for\",\"循环\"],\n        [\"if\",\"倘若\"],\n        [\"instanceof\",\"判断是否为某类实力\"],\n        [\"return\",\"返回\"],\n        [\"switch\",\"枚举式\"],\n        [\"while\",\"循环\"],\n])\n    </script>\n</table>\n<h5>错误处理</h5>\n<table id=\"Ad\">\n    <script>\n        _MiMethod.td('Ad',[\n        [\"assert\",\"断言表达式是否为真\"],\n        [\"catch\",\"捕捉 error\"],\n        [\"finally\",\"最终执行\"],\n        [\"throw\",\"抛出\"],\n        [\"throws\",\"\"],\n        [\"try\",\"尝试执行\"],\n    ])\n    </script>\n</table>\n<h5>包</h5>\n<table id=\"Ae\">\n   <script>\n        _MiMethod.td(\"Ae\",[\n        [\"import\",\"引入\"],\n        [\"package\",\"包\"],\n    ])\n   </script>\n</table>\n\n<h5>保留字</h5>\n<table id=\"Ah\">\n    <script>\n        _MiMethod.td(\"Ah\",[\n        [\"goto\",\"滚去\"],\n        [\"const\",\"定义常量（在 JS 中）\"],\n    ])\n    </script>\n</table>","pageTitle":"java ✈︎✈︎ java ✈︎✈︎ 基础","title":"关键字"},"__N_SSG":true}