{"pageProps":{"data":"<h5>date</h5>\n<table id=\"Aa\">\n    <script>\n        _MiMethod.td(\"Aa\", [\n            [\"after\", \"是否为指定时间后\"],\n            [\"before\", \"是否为指定时间前\"],\n            [\"clone\", \"复制\"],\n            [\"compareTo\", \"比较两个时间的先后\"],\n            [\"equals\", \"比较是否相等\"],\n            [\"getTime\", \"返回毫秒数\"],\n            [\"hashCode\", \"返回哈希值\"],\n            [\"setTime\", \"以毫秒数设置时间\"],\n            [\"toString\", \"转化为字符串\"],\n        ])\n    </script>\n</table>\n<h5>时间和日期的格式化编码</h5>\n<table id=\"Ab\">\n    <script>\n        _MiMethod.td(\"Ab\", [\n            [\"G\", \"纪元标记\"],\n            [\"y\", \"year 四位年分\"],\n            [\"M\", \"month 月份\"],\n            [\"d\", \"day 日\"],\n            [\"h \", \"hour 小时(12 小时制)\"],\n            [\"H\", \"hour 小时(24 小时制)\"],\n            [\"m\", \"minute  分钟\"],\n            [\"s\", \"second 秒\"],\n            [\"S\", \"millisecond 毫秒数\"],\n            [\"E\", \"星期几\"],\n            [\"D\", \"一年中的第几天\"],\n            [\"F\", \"一个月第几个周的周几\"],\n            [\"w\", \"一年中的第几周\"],\n            [\"W\", \"一个月中的第几周\"],\n            [\"a\", \"A.M./P.M. 标记\"],\n            [\"k\", \"一天中的小时（1 - 24）\"],\n            [\"K\", \"A.M./P.M. （0-11） 格式小时\"],\n            [\"z\", \"时区\"],\n        ]);\n    </script>\n</table>\n<h5>printf 格式化日期</h5>\n<table id=\"Ac\">\n    <script>\n        _MiMethod.td(\"Ac\", [\n            [\"%tY\", \"输出四位数的年份\", \"1993\"],\n            [\"%ty\", \"输出两位数的年份\", \"93\"],\n            [\"%tm\", \"输出两位数的月份\", \"04\"],\n            [\"%tB\", \"输出月份的全名\", \"February\"],\n            [\"%tb\", \"输出月份的缩写\", \"Feb\"],\n            [\"%tA\", \"输出星期的全名\", \"Wednesday\"],\n            [\"%ta\", \"输出星期的缩写\", \"Wed\"],\n            [\"%tc\", \"输出全部日期和时间信息\", \"\"],\n            [\"%td\", \"输出两位数的日期\", \"24\"],\n            [\"%tD\", \"输出月日年格式\", \"04/20/93\"],\n            [\"%te\", \"输出一位或两位数的日期\", \"24 或 02\"],\n            [\"%tF\", \"年月日形式\", \"1993-04-20\"],\n            [\"%tH\", \"输出24小时制的小时数\", \"23\"],\n            [\"%tI\", \"输出12小时制的小时数\", \"11\"],\n            [\"%tM\", \"输出分钟数\", \"45\"],\n            [\"%tr\", \"输出 HH:MM:SS PM 格式\", \"04:38:28 下午\"],\n            [\"%tR\", \"输出 HH:MM\", \"16:38\"],\n            [\"%tS\", \"输出秒数\", \"30\"],\n            [\"%tT\", \"输出 HH:MM:SS PM 格式\", \"16:38:28\"],\n            [\"%tp\", \"输出上午还是下午\", \"AM 或 PM\"],\n            [\"%tZ\", \"输出时区\", \"GMT+08:00\"]\n        ]);\n    </script>\n</table>\n<ul>\n    ,\n</ul>","pageTitle":"java ✈︎✈︎ java ✈︎✈︎ 基础","title":"date time"},"__N_SSG":true}