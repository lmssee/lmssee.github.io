{"pageProps":{"data":"<h5>算数运算符</h5>\n<table id=\"Aa\">\n    <script>\n        _MiMethod.td(\"Aa\",[\n        [\"+\",\"加\"],\n        [\"-\",\"减\"],\n        [\"*\",\"乘\"],\n        [\"/\",\"除\"],\n        [\"%\",\"取余\"],\n        [\"++\",\"加加\"],\n        [\"--\",\"减减\"],\n    ])\n    </script>\n</table>\n<h5>关系运算符</h5>\n<table id=\"Ab\">\n    <script>\n        _MiMethod.td(\"Ab\",[\n        [\"==\",\"等\"],\n        [\"!=\",\"不等\"],\n        [\">\",\"大\"],\n        [\"<\",\"小\"],\n        [\">=\",\"不小于\"],\n        [\"<=\",\"不大于\"],\n    ])\n    </script>\n</table>\n<h5>位运算符</h5>\n<table id=\"Ac\">\n    <script>\n        _MiMethod.td(\"Ac\",[\n        [\"&\",\" 1 1 得 1，否则得 0\"],\n        [\"|\",\" 0 0 得 0，否则得 1\"],\n        [\"^\",\"值同为 0 ，否则为 1\"],\n        [\"~\",\"按位取反\"],\n        [\"<<\",\"左移\"],\n        [\">>\",\"右移\"],\n        [\">>>\",\"按位右移并补零\"],\n    ])\n    </script>\n</table>\n<h5>逻辑运算符</h5>\n<table id=\"Ad\">\n    <script>\n        _MiMethod.td(\"Ad\",[\n    [\"&&\",\"且\"],\n    [\"||\",\"或\"],\n    [\"!\",\"取反\"],\n    ])\n    </script>\n</table>\n<h5>赋值运算符</h5>\n<table id=\"Ae\">\n    <script>\n        _MiMethod.td('Ae',[\n    [\"=\",\"\"],\n    [\"+=\",\"\"],\n    [\"-=\",\"\"],\n    [\"*=\",\"\"],\n    [\"/=\",\"\"],\n    [\"(%)=\",\"\"],\n    [\"<<=\",\"\"],\n    [\">>=\",\"\"],\n    [\"&=\",\"\"],\n    [\"^=\",\"\"],\n    [\"|=\",\"\"],\n    ])\n    </script>\n</table>\n<h5>其他运算符</h5>\n<table id=\"Af\"><script>\n    _MiMethod.td(\"Af\",[\n    [\"?:\",\"三目\"],\n    [\"instanceof\",\"检查某对象是否为某一特定的类型\"],\n    [\"\",\"\"],\n    [\"\",\"\"],\n    ])\n</script></table>","pageTitle":"java ✈︎✈︎ java ✈︎✈︎ 基础","title":"运算符"},"__N_SSG":true}