{"pageProps":{"data":"<h5>单字符</h5>\n<p>可以用于实例化一个字符：</p>\n<code class=\"c\">\n<span class=\"p\">new Character(\"\");</span>\n</code>\n<h5>方法</h5>\n<table id=\"Ab\">\n    <script>\n        _MiMethod.td(\"Ab\",[\n        [\"isLetter\",\"是否为字母\"],\n        [\"isDigit\",\"是否为数字字符\"],\n        [\"isWhitespace\",\"是否为空\"],\n        [\"isLowerCase\",\"是否为小写字母\"],\n        [\"isUpperCase\",\"是否为大写字母\"],\n        [\"toUpperCase\",\"转化为大写字母\"],\n        [\"toLowerCase\",\"转换为小写字母\"],\n        [\"toString\",\"转化为字符串\"],\n    ])\n    </script>\n</table>\n<h5>转义序列</h5>\n<table id=\"Aa\">\n    <script>\n        _MiMethod(\"Aa\",[\n        [\"\\\\t\",\"tab 键\"],\n        [\"\\\\b\",\"后退\"],\n        [\"\\\\n\",\"换行\"],\n        [\"\\\\r\",\"回车\"],\n        [\"\\\\f\",\"换页\"],\n        [\"\\\\'\",\"单引号\"],\n        [\"\\\\\\\"\",\"双引号\"],\n        [\"\\\\\\\\\",\"反斜杠\"],\n    ])\n    </script>\n</table>","pageTitle":"java ✈︎✈︎ java ✈︎✈︎ 基础","title":"character"},"__N_SSG":true}