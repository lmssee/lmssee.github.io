{"pageProps":{"data":"<h5>内置数据类型</h5>\n<p>所有包装类都是 Number 的子类。</p>\n<h5>方法</h5>\n<table id=\"Aa\">\n    <script>\n        _MiMethod.td(\"Aa\", [\n            [\"Value\", \"返回 Number 对象转换的数值\"],\n            [\"compareTo\", \"将 number 与参数对照比较\"],\n            [\"equals\", \"判断是否相等\"],\n            [\"valueOf\", \"返回一个 Number 对象指定的内置数据类型\"],\n            [\"toString\", \"返回字符串形式\"],\n            [\"parseInt\", \"将字符串解析乘 int 类型\"],\n            [\"abs\", \"返回掺乎的绝对值\"],\n            [\"ceil\", \"返回大于等于参数的的最小整数，类型为双精度浮点数\"],\n            [\"floor\", \"返回小于等于参数的最小整数\"],\n            [\"print\", \"返回与参数最接近的 double 整数\"],\n            [\"round\", \"四舍五入\"],\n            [\"min\", \"返回两个参数中较小的那个\"],\n            [\"max\", \"\"],\n            [\"exp\", \"返回 e 的参数次方\"],\n            [\"log\", \"\"],\n            [\"pow\", \"返回第一个参数的第二个参数次方\"],\n            [\"sqrt\", \"算术平方根\"],\n            [\"sin\", \"正弦值\"],\n            [\"cos\", \"余弦值\"],\n            [\"tan\", \"正切\"],\n            [\"asin\", \"反正弦\"],\n            [\"acos\", \"反余弦\"],\n            [\"atan\", \"反正切\"],\n            [\"atan2\", \"将笛卡尔坐标切换成极坐标\"],\n            [\"toDegrees\", \"将参数转化为角度\"],\n            [\"toRadians\", \"将角度转换为弧度\"],\n            [\"random\", \"随机\"],\n        ])\n    </script>\n</table>","pageTitle":"java ✈︎✈︎ java ✈︎✈︎ 基础","title":"number"},"__N_SSG":true}