{"pageProps":{"data":"<table id=\"Ae\">\n    <caption>鼠标事件</caption>\n    <tr>\n        <th width=\"30%\">事件</th>\n        <th>当......时发生</th>\n    </tr>\n</table>\n<table id=\"Ad\">\n    <caption>键盘事件</caption>\n    <tr>\n        <th width=\"40%\">事件</th>\n        <th>当......时发生</th>\n    </tr>\n</table>\n<table id=\"Ac\">\n    <caption>DOM 事件</caption>\n    <tr>\n        <th width=\"40%\">事件</th>\n        <th>当.....时发生</th>\n    </tr>\n</table>\n<table id=\"Ab\">\n    <caption>表单事件</caption>\n    <tr>\n        <th width=\"40%\">事件</th>\n        <th>当.....时发生</th>\n    </tr>\n</table>\n<table id=\"Aa\">\n    <caption>新增 media 属性</caption>\n    <tr>\n        <th>事件属性</th>\n        <th>描述</th>\n    </tr>\n</table>\n\n<script>\n    let Ae = [\n        ['onclick', '点击',],\n        ['oncontextmenu', '在一个元素上单击鼠标右键以弹出菜单',],\n        ['ondrag', '元素被拖动',],\n        ['ondragend', '在拖动操作的末端',],\n        ['ondragenter', '当元素已被拖动到有效位置',],\n        ['ondragleave', '当元素离开有效拖放目标',],\n        ['ondragover', '当元素在有效元素上正在被拖动时',],\n        ['ondragstart', '当拖动元素拖动开始',],\n        ['ondrop', '当被拖元素正在被拖动时',],\n        ['ondblclick', '双击',],\n        ['onmousedown', '鼠标按下',],\n        ['onmouseenter', '鼠标指针移到某元素上',],\n        ['onmouseleave', '鼠标指针离开该元素',],\n        ['onmousemove', '鼠标指针在元素上移动',],\n        ['onmouseover', '鼠标指针移动到元素或其子元素上',],\n        ['onmousewheel', '当鼠标滚轮正在被滚动时',],\n        ['onscroll', '当元素',],\n    ];\n    _MiMethod.td('Ae', Ae);\n    let Ad = [\n        ['onkeydown', '用户正按下一个键',],\n        ['onkeypress', '用户按下并释放一个按键',],\n        ['onkeyup', '用户释放一个按键',],\n    ];\n    _MiMethod.td('Ad', Ad);\n    let Ac = [\n        ['onafterprint', '文件打印之后运行的脚本',],\n        ['onbeforeprint', '文件打印前运行的脚本',],\n        ['onbeforeunload', '文件卸载之前运行的脚本',],\n        ['onhaschange', '当文档已改变时运行的脚本',],\n        ['onerror', '当加载文件出错',],\n        ['onload', '已经加载一个对象',],\n        ['onresize', '重新调整文档视图大小',],\n        ['onscroll', '滚动了元素的滚动条',],\n        ['onmessage', '当消息被触发时',],\n        ['onoffline', '文档离线时',],\n        ['ononline', '文档上线时',],\n        ['onpagehide', '窗口隐藏时',],\n        ['onpageshow', '窗口可见时',],\n        ['onpopstate', '窗口历史记录改变时',],\n        ['onredo', '文件执行撤销（redo）',],\n        ['onstorage', '在 Web Storage 区域更新后',],\n        ['onundo', '在文档执行 undo 时',],\n    ];\n    _MiMethod.td('Ac', Ac);\n    let Ab = [\n        ['onblur', '一个元素失去焦点',],\n        ['onchange', '内容、选取或选中的状态发生了变化',],\n        ['oncontextmenu', '当上下文菜单被触发时',],\n        ['onfocus', '一个元素获得焦点',],\n        ['onforminput', '当表单获得用户输入时',],\n        ['oninput', '当元素获得用户输入时',],\n        ['oninvalid', '当元素无效时',],\n        ['onreset', '重置一个表单',],\n        ['onselect', '用户选择了一些文本',],\n        ['onsubmit', '提交一个表单',],\n    ];\n    _MiMethod.td('Ab', Ab);\n    let Aa = [\n        ['oncanplay', '文件就绪可以播放',],\n        ['oncanplaythrough', '当媒介能够无需因缓冲而停止即可播放至结尾',],\n        ['ondurationchange', '当媒介长度改变时',],\n        ['onemptied', '当发生故障并且文件忽然不可用时',],\n        ['onended', '媒介已到达结尾时',],\n        ['onerror', '文件加载期间发生错误',],\n        ['onloadeddata', '当媒介元素已加载时',],\n        ['onloadedmetadata', '当元数据（分辨率和时长）被加载时',],\n        ['onloadstart', '当文件开始加载且未实际加载任何数据前',],\n        ['onpause', '当媒介被用户或程序暂停时',],\n        ['onplay', '当媒介已就绪可以播放时',],\n        ['onplaying', '当媒介已经开始播放时',],\n        ['onprogress', '当浏览器正在获取媒介数据时',],\n        ['onratechange', '当回放速率改变时',],\n        ['onreadystatechange', '就绪状态发生改变时',],\n        ['onseeked', '当 seeking 属性设置为 false （指示定位已结束）时',],\n        ['onstalled', '在浏览器无论何种原因未能取回媒介元素数据时',],\n        ['onsuspend', '当媒介数据完全加载之前无论何种原因终止取回媒介数据',],\n        ['ontimeupdate', '当播放位置改变时',],\n        ['onvolumechange', '每当音量改变时',],\n    ];\n    _MiMethod.td('Aa', Aa);\n</script>","pageTitle":"h-j-c ✈︎✈︎ js ✈︎✈︎ 事件 event","title":"all"},"__N_SSG":true}